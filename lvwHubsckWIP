MainTab:Button({
    Title = "Monster Information",
    Callback = function()

        local list = ""

        for _,plr in pairs(Players:GetPlayers()) do
            local hasMonster =
                (plr.Backpack:FindFirstChild("Monster") or
                (plr.Character and plr.Character:FindFirstChild("Monster")))

            if hasMonster then
                list = list .. "\nDisplay: "..plr.DisplayName.." | @"..plr.Name
            end
        end

        WindUI:Notify({
            Title = "Monster Players",
            Content = list ~= "" and list or "Tidak ada Monster",
            Duration = 5
        })
    end
})

