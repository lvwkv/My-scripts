-- Function untuk shoot ke monster
local function shootAtMonster()
    -- Cek apakah local player punya gun
    if not localPlayerHasGun() then
        WindUI:Notify({
            Title = "Shoot Monster",
            Content = "Kamu tidak punya gun! Jadi Sheriff dulu.",
            Duration = 2
        })
        return
    end
    
    -- Cari monster
    local monster = getPlayerWithItem("Monster")
    if not monster or not monster.Character then
        WindUI:Notify({
            Title = "Shoot Monster",
            Content = "Monster tidak ditemukan!",
            Duration = 2
        })
        return
    end
    
    -- Ambil posisi HRP monster
    local monsterHRP = monster.Character:FindFirstChild("HumanoidRootPart")
    if not monsterHRP then
        WindUI:Notify({
            Title = "Shoot Monster",
            Content = "Tidak bisa mendapatkan posisi monster!",
            Duration = 2
        })
        return
    end
    
    -- Cek apakah monster terlihat di layar
    local monsterScreenPos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(monsterHRP.Position)
    
    if not onScreen then
        WindUI:Notify({
            Title = "Shoot Monster",
            Content = "Monster tidak terlihat di layar!",
            Duration = 2
        })
        return
    end
    
    -- Move mouse ke posisi monster dan klik
    mousemoveabs(monsterScreenPos.X, monsterScreenPos.Y)
    task.wait(0.03)
    mouse1press()
    task.wait(0.05)
    mouse1release()
    
    -- Update status dot ke merah sebentar (feedback)
    statusDot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    task.delay(0.3, function()
        statusDot.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
    end)
end

