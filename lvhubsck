-- =========================
-- DETECT MONSTER NEAR GUN
-- =========================

local function monsterNearGun()
    local gunPart = getGunPart()
    if not gunPart then return false end

    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local hasMonster =
                plr.Backpack:FindFirstChild("Monster") or
                plr.Character:FindFirstChild("Monster")

            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")

            if hasMonster and hrp then
                if (hrp.Position - gunPart.Position).Magnitude < 25 then
                    return true
                end
            end
        end
    end

    return false
end

task.spawn(function()
    while true do
        btn.Visible = monsterNearGun()
        task.wait(0.5)
    end
end)

-- =========================
-- SHOOT MODE (AIM ASSIST)
-- =========================

MainTab:Toggle({
    Title = "Shoot Monster (Assist)",
    Default = false,
    Callback = function(v)
        ShootMode = v
    end
})

local function getMonsterTarget()
    for _,plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if plr.Character:FindFirstChild("Monster") then
                return plr
            end
        end
    end
end

task.spawn(function()
    while true do
        if ShootMode then
            local char = LocalPlayer.Character
            if char and (char:FindFirstChild("Gun") or LocalPlayer.Backpack:FindFirstChild("Gun")) then

                local target = getMonsterTarget()

                if target and target.Character then
                    local head = target.Character:FindFirstChild("Head")
                    if head then
                        workspace.CurrentCamera.CFrame =
                            CFrame.new(workspace.CurrentCamera.CFrame.Position, head.Position)
                    end
                end
            end
        end
        task.wait()
    end
end)

