-- =========================
-- GET GUN PART
-- =========================
local function getGunPart()
    local holder = workspace:FindFirstChild("GunPickupHolder")
    if holder then
        local gun = holder:FindFirstChild("GunPickup")
        if gun then
            return gun:FindFirstChild("Part")
        end
    end
end

-- =========================
-- HAS ITEM CHECKER
-- =========================
local function hasItem(player, name)
    return player.Backpack:FindFirstChild(name)
        or (player.Character and player.Character:FindFirstChild(name))
end

-- =========================
-- GET SINGLE PLAYER WITH ITEM
-- =========================
local function getPlayerWithItem(itemName)
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            if hasItem(plr, itemName) then
                return plr
            end
        end
    end
    return nil
end

-- =========================
-- ESP PERMANENT
-- =========================
local function analyze(player)
    if not player.Character then return end

    local highlight = player.Character:FindFirstChild("LvHighlight") or Instance.new("Highlight")
    highlight.Name = "LvHighlight"
    highlight.Parent = player.Character
    highlight.Adornee = player.Character
    highlight.Enabled = ESPEnabled
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0

    if hasItem(player, "Monster") then
        highlight.FillColor = Color3.new(1, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 100, 100)
    elseif hasItem(player, "Gun") then
        highlight.FillColor = Color3.new(0, 0, 1)
        highlight.OutlineColor = Color3.fromRGB(100, 100, 255)
    else
        highlight.FillColor = Color3.new(0, 1, 0)
        highlight.OutlineColor = Color3.fromRGB(100, 255, 100)
    end
end

task.spawn(function()
    while true do
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                if ESPEnabled then
                    analyze(plr)
                else
                    local h = plr.Character and plr.Character:FindFirstChild("LvHighlight")
                    if h then h.Enabled = false end
                end
            end
        end
        task.wait(1)
    end
end)

